FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant";
    object      chemistryProperties.vapour;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

chemistryType
{
    solver  EulerImplicit;
}

chemistry   on;

initialChemicalTimeStep 1e-07;

EulerImplicit
{
    cTauChem                1;
}

ode
{
    solver      Rosenbrock43;
    absTol      1e-8;
    relTol      0.01;
}

#include "reactions.vapour"

// ************************************************************************* //
