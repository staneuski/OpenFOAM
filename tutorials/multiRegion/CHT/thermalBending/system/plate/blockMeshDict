FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

scale 0.001;

vertices
(
    (0 0 0)
    (100 0 0)
    (100 5 0)
    (0 5 0)
    (0 0 1)
    (100 0 1)
    (100 5 1)
    (0 5 1)
);

blocks
(
    hex (0 1 2 3 4 5 6 7) (113 5 1) simpleGrading (1.0 1.0 1.0)
);

defaultPatch
{
    type empty;
}

boundary
(
    topSurface
    {
        type patch;
        faces
        (
            (3 7 6 2)
        );
    }

    bottomSurface
    {
        type mappedWall;
        neighbourRegion heatsink;
        neighbourPatch topSurface;
        faces
        (
            (4 0 1 5)
        );
    }

    ends
    {
        type patch;
        faces
        (
            (0 4 7 3)
            (1 2 6 5)
        );
    }
);


