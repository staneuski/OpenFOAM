FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant";
    object      momentumTransport;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

simulationType  LES;

LES
{
    model           kEqn;

    turbulence      on;


    delta           smooth;

    cubeRootVol
    {
        deltaCoeff      1;
    }

    Prandtl
    {
        delta           cubeRootVol;
        cubeRootVol
        {
            deltaCoeff      1;
        }

        smooth
        {
            delta           cubeRootVol;
            cubeRootVol
            {
                deltaCoeff      1;
            }

            maxDeltaRatio   1.1;
        }

        Cdelta          0.158;
    }

    vanDriest
    {
        delta           cubeRootVol;
        cubeRootVol
        {
            deltaCoeff      1;
        }

        smooth
        {
            delta           cubeRootVol;
            cubeRootVol
            {
                deltaCoeff      1;
            }

            maxDeltaRatio   1.1;
        }

        Aplus           26;
        Cdelta          0.158;
    }

    smooth
    {
        delta           cubeRootVol;
        cubeRootVol
        {
            deltaCoeff      1;
        }

        maxDeltaRatio   1.1;
    }
}

