FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant";
    object      momentumTransport;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

simulationType          laminar;

RAS
{
    model               kOmegaSST;

    turbulence          on;
    #print
}

LES
{
    model               SpalartAllmarasDDES;
    delta               cubeRootVol;

    turbulence          on;
    #print

    cubeRootVol
    {
        deltaCoeff      1;
    }

    smooth
    {
        delta           cubeRootVol;
        cubeRootVol
        {
            deltaCoeff      1;
        }
        maxDeltaRatio   1.1;
    }
}

