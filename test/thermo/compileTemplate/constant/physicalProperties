FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant";
    object      physicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            hePsiThermo;
    mixture         pureMixture;
    transport       logPolynomial;
    thermo          hConst;
    equationOfState perfectGas;
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture
{
    specie
    {
        molWeight   28.9;
    }
    thermodynamics
    {
        Cp          1007;
        hf          0;
    }
    transport
    {
        muLogCoeffs<8>  (-19.1 2.49 -0.249 0.0111 0 0 0 0);
        kappaLogCoeffs<8>   (-1.95 -2.072 0.437 -0.022 0 0 0 0);
    }
}


